<div class="mb-8 hidden items-center justify-between sm:flex">
  <div class="font-display flex-1 truncate text-2xl font-medium text-base-content">
    <%= @user.name %>
  </div>
  <%= link_to full_user_share_path(@user), 
    data: {
      turbo_frame: :modal
    },
    class: "flex items-center text-base-content/60 transition-colors hover:text-base-content" do %>
    <span class="i-[tabler--share] size-5"></span>
  <% end %>
</div>

<%= render "users/user_card", user: @user %>

<% if @user.block_user?(current_user) || current_user&.block_user?(@user) %>
  <%= render "shared/empty", text: t('blocked') %>
<% else %>
  <div class="mx-auto max-w-3xl border-t border-base-300 pt-6 text-base-content"
    data-controller="tabs"
    data-tabs-active-tab-value="<%= @tab %>"
    data-tabs-active-class-value="!bg-base-content !text-base-100 !font-semibold">
    <div class="mb-4 flex w-full items-center gap-1 overflow-auto scrollbar-hide">
      <%= link_to user_path(@user, tab: :published),
        class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "published",
          action: "tabs#active"
        } do %>
        <%= t('published') %>
      <% end %>

      <%= link_to user_path(@user, tab: :bought),
        class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "bought",
          action: "tabs#active"
        } do %>
        <%= t('bought') %>
      <% end %>

      <%= link_to user_comments_path(@user),
        class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "commented",
          action: "tabs#active"
        } do %>
        <%= t('commented') %>
      <% end %>
    </div>
    <div class="hidden pb-4"
      data-tabs-content-param="published"
      data-tabs-target="content">
      <%= turbo_frame_tag "#{dom_id @user}_published_articles", src: user_articles_path(@user, tab: :published), target: '_top', loading: :lazy do %>
        <%= render "shared/loading" %>
      <% end %>
    </div> 
    <div class="hidden pb-4"
      data-tabs-content-param="bought"
      data-tabs-target="content">
      <%= turbo_frame_tag "#{dom_id @user}_bought_articles", src: user_articles_path(@user, tab: :bought), target: '_top', loading: :lazy do %>
        <%= render "shared/loading" %>
      <% end %>
    </div> 
    <div class="hidden pb-4"
      data-tabs-content-param="commented"
      data-tabs-target="content">
      <%= turbo_frame_tag "#{dom_id @user}_comments", src: user_comments_path(@user), target: '_top', loading: :lazy do %>
        <%= render "shared/loading" %>
      <% end %>
    </div> 
  </div>
<% end %>

<div class="mt-12 border-t border-base-300 pt-8">
  <%= render "shared/footer" %>
</div>

<% content_for :topbar do %>
  <div class="flex h-12 items-center justify-between">
    <div class="flex items-center truncate px-4">
      <%= link_to :back, class: "pr-2 text-base-content/70" do %>
        <span class="i-[tabler--chevron-left] size-5"></span>
      <% end %>
      <span class="truncate text-lg font-semibold">
        <%= @user.name %>
      </span>
    </div>

    <%= link_to full_user_share_path(@user), 
      data: {
        turbo_frame: :modal
      },
      class: "block px-6 py-3 text-base-content/60 #{from_mixin_messenger? ? 'mr-24' : ''}" do %>
      <span class="i-[tabler--share] size-5"></span>
    <% end %>
  </div>
<% end %>
