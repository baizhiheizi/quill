<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('share') do %>
    <%= render "shared/share_options",
      share_url: user_url(@user),
      share_title: @user.name,
      mixin_href: (from_mixin_messenger? ? share_to_mixin(user_url(@user), title: @user.name, description: @user.bio, icon_url: @user.avatar_url) : nil) %>
  <% end %>
<% end %>
