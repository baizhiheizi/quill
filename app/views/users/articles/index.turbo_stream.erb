<%= turbo_stream.append "#{dom_id @user}_#{@tab}_articles_list" do %>
  <%= render partial: "articles/card", collection: @articles, as: :article %>
<% end %>

<%= turbo_stream.update "#{dom_id @user}_#{@tab}_articles_pagination" do %>
  <%= render "shared/pagination", pagy: @pagy, id: "#{dom_id @user}_#{@tab}_articles_pagination" %>
<% end %>
