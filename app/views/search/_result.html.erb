<div id="search_result_list"
  data-controller="dropdown"
  data-dropdown-target="menu"
  data-dropdown-initial-state-value="show"
  data-action="click@window->dropdown#hide"
  data-transition-enter-active="transition ease-out duration-100"
  data-transition-enter-from="transform opacity-0 scale-95"
  data-transition-enter-to="transform opacity-100 scale-100"
  data-transition-leave-active="transition ease-in duration-75"
  data-transition-leave-from="transform opacity-100 scale-100"
  data-transition-leave-to="transform opacity-0 scale-95"
  class="hidden 
          absolute 
          left-0 
          z-10
          mt-2
          w-full 
          origin-top-left 
          rounded-xl
          border
          border-base-300
          bg-base-100
          p-2
          shadow-lg">
  <% if tags.present? %>
    <div class="px-2 py-1.5 text-xs font-medium text-base-content/60"><%= t('tags') %></div>
    <% tags.each do |tag| %>
      <%= link_to articles_path(tag: tag.name), class: "flex items-center rounded-lg px-2 py-1.5 hover:bg-base-200" do %>
        <span class="tag-chip max-w-full truncate px-2.5 py-1 text-sm">
          <%= tag.name %>
        </span>
      <% end %>
    <% end %>
  <% end %>

  <% if users.present? %>
    <div class="px-2 py-1.5 text-xs font-medium text-base-content/60"><%= t('author') %></div>
    <% users.each do |user| %>
      <%= link_to user_path(user), 
        class: "flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm hover:bg-base-200" do %>
        <span class="block size-6 flex-shrink-0 overflow-hidden rounded-full">
          <%= render "shared/avatar", user:, thumb: true, class: "block h-full w-full rounded-full" %>
        </span>
        <span class="truncate"><%= user.name %></span>
      <% end %>
    <% end %>
  <% end %>

  <div class="my-1 border-t border-base-300"></div>
  <%= link_to t("press_enter_to_search_all_articles"), 
    articles_path(query: query), 
    class: "flex items-center rounded-lg px-2 py-1.5 text-sm text-base-content/60 hover:bg-base-200" %>
</div>
