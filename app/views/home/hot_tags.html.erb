<%= turbo_frame_tag 'hot_tags' do %>
  <% if @hot_tags.present? %>
    <div>
      <div class="mb-3 text-sm font-medium text-base-content/50"><%= t('hot_tags') %></div>
      <% if current_user.blank? %>
        <div class="flex flex-wrap items-center gap-2">
          <% @hot_tags.each do |tag| %>
            <%= link_to tag.name,
              articles_path(tag: tag.name, filter: @filter || 'lately'),
              data: {
                controller: 'prefetch',
                turbo_frame: '_top',
              },
              class: "tag-chip inline-flex max-w-[8rem] truncate px-3 py-1.5 text-sm font-medium transition-colors hover:text-base-content" %>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-wrap items-center gap-2">
          <% @hot_tags.each do |tag| %>
            <div class="tag-chip flex items-center gap-2 px-3 py-1.5 text-sm font-medium">
              <%= link_to tag.name,
                articles_path(tag: tag.name, filter: @filter || 'lately'),
                data: {
                  controller: 'prefetch',
                  turbo_frame: '_top',
                },
                class: "max-w-[6rem] truncate" %>
              <%= render "subscribe_tags/subscribe_button", tag: tag %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
