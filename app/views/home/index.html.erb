<%# Editorial redesign (FR-001/FR-002): slim masthead (rendered by the
    "public" layout) + a one-line value prop for logged-out visitors only —
    no full-height hero banner. The feed begins immediately below. %>
<% if current_user.blank? %>
  <div class="mb-8 text-center sm:mb-10">
    <p class="font-display text-lg text-base-content sm:text-xl">
      <%= t('home_value_proposition') %>
    </p>
  </div>
<% end %>

<%= turbo_frame_tag 'articles', src: articles_path do %>
  <%= render 'shared/loading' %>
<% end %>

<div class="mt-12 space-y-10 border-t border-base-300 pt-8">
  <%= turbo_frame_tag 'active_authors', src: active_authors_path, loading: :lazy %>
  <%= turbo_frame_tag 'hot_tags', src: hot_tags_path, loading: :lazy %>
  <%= render 'shared/footer' %>
</div>
