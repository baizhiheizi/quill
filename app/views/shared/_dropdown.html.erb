<div class="dropdown relative inline-flex <%= local_assigns[:class] %>" data-controller="flyonui-dropdown">
  <button type="button" class="dropdown-toggle block" aria-haspopup="menu" aria-expanded="false">
    <%= button %>
  </button>

  <div class="dropdown-menu dropdown-open:opacity-100 hidden min-w-48 rounded-xl border border-base-300 bg-base-100 p-1 shadow-lg" role="menu">
    <%= menu %>
  </div>
</div>
