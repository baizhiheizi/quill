<div
  id="app-modal"
  class="overlay modal modal-middle overlay-open:opacity-100 overlay-open:duration-300 hidden <%= classes %>"
  role="dialog"
  tabindex="-1"
  data-controller="modal-component"
  data-action="turbo:submit-end->modal-component#submitEnd"
  data-modal-component-backdrop-value="<%= backdrop %>">
  <div class="modal-dialog w-full max-w-2xl sm:max-w-lg">
    <div class="modal-content">
      <div class="modal-header border-b border-base-content/10">
        <% if header.present? %>
          <%= header %>
        <% else %>
          <h3 class="modal-title text-base font-bold"><%= title %></h3>
        <% end %>
        <button
          type="button"
          class="btn btn-circle btn-sm btn-text absolute end-3 top-3"
          aria-label="<%= t('close', default: 'Close') %>"
          data-action="modal-component#close">
          <span class="icon-[tabler--x] size-4"></span>
        </button>
      </div>

      <div class="modal-body max-h-[75vh] overflow-y-auto scrollbar-hide">
        <%= content %>
        <div style="height:env(safe-area-inset-bottom)"></div>
      </div>
    </div>
  </div>
</div>
