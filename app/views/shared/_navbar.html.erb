<nav class="navbar fixed top-0 z-50 w-full border-b border-base-300 bg-base-100/95 backdrop-blur-sm lg:hidden">
  <% if content_for? :topbar %>
    <%= yield :topbar %>
  <% else %>
    <div class="navbar-start">
      <%= link_to root_path, data: { controller: 'prefetch' } do %>
        <%= image_tag 'logo.svg', class: "h-8 w-auto dark:hidden" %>
        <%= image_tag 'logo-light.svg', class: "hidden h-8 w-auto dark:block" %>
      <% end %>
    </div>
    <% if current_user.present? %>
      <div class="navbar-end <%= from_mixin_messenger? ? 'mr-24' : '' %>">
        <%= link_to dashboard_notifications_path, class: "btn btn-soft btn-circle btn-sm", "aria-label": t('notification') do %>
          <span class="indicator">
            <span class="i-[tabler--bell] size-5 text-base-content/60"></span>
            <% if current_user.has_unread_notification? %>
              <span class="indicator-item badge badge-error badge-xs"></span>
            <% end %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</nav>
