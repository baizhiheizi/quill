<!DOCTYPE html>
<% @page_title = @page_title.presence || Settings.page_title %>
<% @page_description ||= Settings.page_description %>
<% @page_keywords ||= Settings.page_keywords %>
<% @page_image ||= asset_url('article-poster-bg.png') %>

<html lang="<%= I18n.locale %>" data-theme="quill">
  <head>
    <title><%= @page_title %></title>
    <meta
      name='viewport'
      content='minimum-scale=1, initial-scale=1, width=device-width, user-scalable=no, shrink-to-fit=no, viewport-fit=cover'
    />
    <meta name="theme-color" content="#fff" />

    <meta name='title' content="<%= @page_title %>">
    <meta name='keywords' content="<%= @page_keywords %>">
    <meta name='description' content="<%= @page_description %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@<%= Settings.twitter_account %>" />
    <meta name="twitter:creator" content="@<%= Settings.twitter_account %>" />
    <meta name="twitter:title" content="<%= @page_title %>">
    <meta name="twitter:description" content="<%= @page_description %>">
    <meta name="twitter:image" content="<%= @page_image %>">

    <meta property="og:url" content="<%= request.original_url %>" />
    <meta property="og:title" content="<%= @page_title %>" />
    <meta property="og:description" content="<%= @page_description %>" />
    <meta property="og:image" content="<%= @page_image %>" />

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% if Rails.env.development? %>
      <script src="https://unpkg.com/vconsole@latest/dist/vconsole.min.js"></script>
      <script>
        // VConsole will be exported to `window.VConsole` by default.
        if (window.VConsole) {
          let vConsole = new window.VConsole();
        }
      </script>
    <% end %>

    
    <% if current_user.blank? %>
      <script>
        // Ensure to clear session before login;
        // Avoid stange behavior on Android Mixin Webview
        document.cookie = "_quill_sessions=; Max-Age=0"
      </script>
    <% end %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,500;0,600;1,500&family=Noto+Serif+SC:wght@500;600&family=Inter:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;600&display=swap" rel="stylesheet">
    <%= favicon_link_tag "favicon.svg" %>
    <script>
      (function () {
        var theme = localStorage.theme;
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.dataset.theme = 'quill-dark';
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload" %>
  </head>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TNT4ZMVDL4"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-TNT4ZMVDL4');
  </script>

  <body class="flex min-h-screen justify-center overflow-x-hidden bg-base-100 text-base-content">
    <%= render 'shared/navbar' if browser.device.mobile? %>
    <%= render 'shared/dashboard_tabbar' if browser.device.mobile? %>
    <div class="w-full max-w-full lg:flex">
      <%= render 'shared/dashboard_rail' if current_user.present? && !browser.device.mobile? %>

      <main class="flex w-full max-w-full 2xl:max-w-screen-2xl pt-12 pb-24 sm:py-0">
        <div class="w-full <%= content_for?(:sidebar) ? 'lg:w-[48rem] 2xl:w-[64rem]' : 'lg:max-w-5xl 2xl:max-w-6xl mx-auto' %>">
          <div class="w-full py-4 px-6 sm:p-8">
            <%= yield %>
          </div>
        </div>

        <% if content_for?(:sidebar) %>
          <%# Dashboard pages default to no right rail — the public-page
              widgets (join-Quill card, active-authors/hot-tags, footer) are
              marketing/discovery content with no dashboard relevance, and
              removing them reclaims width for denser workspace layouts
              (research.md §6). Pages may still opt in via content_for(:sidebar). %>
          <aside class="relative hidden min-h-screen w-80 border-l border-base-300 p-6 xl:block">
            <div class="sticky top-8 space-y-8">
              <%= yield :sidebar %>
            </div>
          </aside>
        <% end %>
      </main>
    </div>

    <%= turbo_frame_tag 'modal' %>

    <div data-controller="darkmode">
    </div>

    <div class="fixed bottom-24 h-0 w-full px-4 z-50 flex flex-col justify-end" id="flashes">
      <% flash.each do |type, message| %>
        <%= render "flashes/flash", type: type, message: message %>
      <% end %>
    </div>

    <div class="absolute bottom-0" id="toast-slot">
      <div id="loading-toast" class="hidden fixed inset-0 z-50 flex items-center justify-center w-full bg-black/30">
        <%= render "shared/loading" %>
      </div>
    </div>
    <%= turbo_stream_from "user_#{current_user.mixin_uuid}" if current_user.present? %>
  </body>
</html>
