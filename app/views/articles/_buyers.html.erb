<div class="flex flex-col items-center justify-center mb-8">
  <%# Read preloaded counts when the controller primed them, fall back to
      live counts when the partial is rendered from a site that didn't
      (e.g. dashboard/admin article previews). The preloaded path is what
      the public show view uses and saves 2 SELECTs (one grouped query
      for both counts instead of two separate count queries). %>
  <% buy_orders_count = defined?(@buy_orders_count) ? @buy_orders_count : article.buy_orders.count %>
  <% reward_orders_count = defined?(@reward_orders_count) ? @reward_orders_count : article.reward_orders.count %>
  <% readers_count = defined?(@readers_count) ? @readers_count : article.readers.distinct.count %>
  <div class="inline-flex items-center justify-center space-x-3 px-4 py-2 rounded-full bg-base-200/50 text-sm border border-base-content/5 mb-6">
    <div class="flex items-center space-x-1.5">
      <span class="text-primary font-bold"><%= buy_orders_count %></span>
      <span class="text-base-content/60"><%= t('times_bought') %></span>
    </div>
    <span class="text-base-content/20">•</span>
    <div class="flex items-center space-x-1.5">
      <span class="text-primary font-bold"><%= reward_orders_count %></span>
      <span class="text-base-content/60"><%= t('times_reward') %></span>
    </div>
  </div>

  <% if readers_count.positive? %>
    <div class="w-full max-w-sm mb-10 <%= readers_count > 8 ? 'grid grid-cols-8 gap-1.5 sm:gap-2' : 'flex items-center justify-center space-x-2' %>">
      <%# Use the controller's preloaded sample (avatar chain eager-loaded)
          when present — saves ~3 SELECTs per reader for the shared
          `_avatar` partial. Fall back to the live helper otherwise. %>
      <% random_readers = defined?(@random_readers) ? @random_readers : article.random_readers(24) %>
      <% random_readers.each do |reader| %>
        <div class="avatar tooltip" data-tip="<%= reader.name %>">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full ring-2 ring-base-100 hover:ring-primary transition-all cursor-pointer">
            <%= render "shared/avatar", user: reader, thumb: true, class: "rounded-full" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if article.authorized? user %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <div class="col-span-1 flex flex-col items-center justify-center p-4 rounded-2xl bg-base-200/30 border border-base-content/5">
      <div class="text-2xl font-display font-semibold text-base-content mb-1">
        <%= article.price %>
      </div>
      <div class="text-xs uppercase tracking-wider font-semibold text-base-content/60">
        <%= t('activerecord.attributes.article.price') %>(<%= article.currency.symbol %>)
      </div>
    </div>
    <div class="col-span-1 flex flex-col items-center justify-center p-4 rounded-2xl bg-base-200/30 border border-base-content/5">
      <div class="text-2xl font-display font-semibold text-base-content mb-1">
        <%= article.orders_count %>
      </div>
      <div class="text-xs uppercase tracking-wider font-semibold text-base-content/60">
        <%= t('activerecord.attributes.article.orders_count') %>
      </div>
    </div>
    <div class="col-span-1 flex flex-col items-center justify-center p-4 rounded-2xl bg-base-200/30 border border-base-content/5">
      <div class="text-2xl font-display font-semibold text-base-content mb-1">
        $<%= article.revenue_usd.presence&.round(2) || '0.00' %>
      </div>
      <div class="text-xs uppercase tracking-wider font-semibold text-base-content/60">
        <%= t('activerecord.attributes.article.revenue') %>
      </div>
    </div>
    <div class="col-span-1 flex flex-col items-center justify-center p-4 rounded-2xl bg-base-200/30 border border-base-content/5">
      <div class="text-2xl font-display font-semibold text-base-content mb-1">
        <%= (article.share_of(user).to_f * 100).round(1) %>%
      </div>
      <div class="text-xs uppercase tracking-wider font-semibold text-base-content/60">
        <%= t('activerecord.attributes.article.my_share') %>
      </div>
    </div>
  </div>
<% end %>
