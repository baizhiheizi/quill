<div class="min-h-screen bg-base-100" data-controller="preview">
  <div class="border-b border-base-300 bg-base-100/95 px-4 py-3 backdrop-blur-sm">
    <div class="mx-auto flex max-w-3xl items-center justify-between">
      <span class="text-sm font-medium opacity-70"><%= t("articles.preview") %></span>
      <button type="button"
        class="btn btn-soft btn-sm"
        data-action="click->preview#close">
        <%= t("articles.close_preview") %>
      </button>
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-8">
    <% if @article.free? %>
      <%= render "articles/full_content", article: @article, user: @preview_user %>
    <% else %>
      <%= render "articles/partial_content", article: @article, user: @preview_user %>
    <% end %>
  </article>
</div>
