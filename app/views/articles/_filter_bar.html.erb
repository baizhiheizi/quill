<div
  data-controller="tabs"
  data-tabs-active-tab-value="<%= filter %>"
  data-tabs-active-class-value="!bg-base-content !text-base-100 !font-semibold">
  <div class="mb-4 flex w-full flex-nowrap items-center gap-1 overflow-auto scrollbar-hide">
    <%= link_to '/more', class: "mr-1 flex-shrink-0 rounded-full p-2 text-base-content/60 sm:hidden" do %>
      <span class="i-[tabler--plus] size-4"></span>
    <% end %>

    <%= link_to t('order_by_popularity'),
      articles_path(filter: :default),
      class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "default",
      } %>

    <% if current_user.present? && current_user.subscribe_users.present? %>
      <%= link_to t('subscribed'),
        articles_path(filter: :subscribed),
        class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
        data: {
          controller: 'prefetch',
          tabs_target: "tab",
          tabs_tabname_param: "subscribed",
        } %>
    <% end %>

    <% if current_user.present? && current_user.bought_articles_count > 0 %>
      <%= link_to t('bought'),
        articles_path(filter: :bought),
        class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
        data: {
          controller: 'prefetch',
          tabs_target: "tab",
          tabs_tabname_param: "bought",
        } %>
    <% end %>

    <%= link_to t('order_by_lately'),
      articles_path(filter: :lately),
      class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "lately",
      } %>

    <%= link_to t('order_by_revenue'),
      articles_path(filter: :revenue, time_range: :month),
      class: "flex-shrink-0 rounded-full px-3 py-1.5 text-sm text-base-content/60 transition-colors hover:bg-base-200",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "revenue",
      } %>
  </div>
</div>

<% if filter == 'revenue' %>
  <div class="mb-4 flex w-full flex-nowrap items-center gap-4 overflow-auto scrollbar-hide text-sm"
    data-controller="tabs"
    data-tabs-active-tab-value="<%= time_range %>"
    data-tabs-active-class-value="!text-base-content !font-semibold">
    <%= link_to t('in_a_week'),
      articles_path(filter: :revenue, time_range: :week),
      class: "flex-shrink-0 text-base-content/60",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "week",
      } %>
    <%= link_to t('in_a_month'),
      articles_path(filter: :revenue, time_range: :month),
      class: "flex-shrink-0 text-base-content/60",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "month",
      } %>
    <%= link_to t('in_a_year'),
      articles_path(filter: :revenue, time_range: :year),
      class: "flex-shrink-0 text-base-content/60",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "year",
      } %>
    <%= link_to t('all'),
      articles_path(filter: :revenue, time_range: :all),
      class: "flex-shrink-0 text-base-content/60",
      data: {
        controller: 'prefetch',
        tabs_target: "tab",
        tabs_tabname_param: "all",
      } %>
  </div>
<% end %>
