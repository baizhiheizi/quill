<%# "Minimal List" row (design doc §6.1) — the single shared article preview
    component reused by the home feed, search results (via the same feed),
    author profile articles tab, and collection articles (research.md). %>
<article class="group relative border-b border-base-300 py-5 sm:py-6" data-article-card>
  <div class="relative z-10 mb-2 flex flex-wrap items-center gap-1.5">
    <% if article.free? %>
      <span class="tag-chip inline-flex items-center px-2 py-0.5 text-[11px] font-medium">
        <%= t('free', default: 'Free') %>
      </span>
    <% else %>
      <span class="inline-flex items-center rounded-full bg-base-content px-2 py-0.5 text-[11px] font-medium text-base-100">
        <%= article.price_tag %>
      </span>
    <% end %>

    <% article.tags.first(3).each do |tag| %>
      <%= link_to tag.name, articles_path(tag: tag.name),
        data: { controller: 'prefetch', turbo_frame: '_top' },
        class: "tag-chip inline-flex max-w-[8rem] truncate px-2 py-0.5 text-[11px] font-medium transition-colors hover:text-base-content" %>
    <% end %>

    <%# Cross-Locale Article Visibility (FR-010, SC-007): surface the article's language regardless of the viewer's own locale. %>
    <% if article.locale.present? %>
      <span class="article-card__locale badge badge-soft badge-xs font-medium uppercase" title="<%= I18n.t("languages.#{article.locale}", default: article.locale) %>">
        <%= article.locale %>
      </span>
    <% end %>
  </div>

  <%= link_to user_article_path(article.author, article),
    data: { controller: "prefetch", turbo_frame: "_top" },
    class: "relative z-10 flex items-start gap-4 sm:gap-6" do %>
    <div class="min-w-0 flex-1">
      <h2 class="font-display line-clamp-2 text-base leading-snug font-medium text-base-content decoration-1 underline-offset-2 group-hover:underline sm:text-lg">
        <%= article.title %>
      </h2>
      <p class="mt-1 line-clamp-1 text-sm text-base-content/60">
        <%= article.intro %>
      </p>
    </div>

    <% if article.thumb_url.present? %>
      <div class="size-20 flex-shrink-0 overflow-hidden rounded-lg bg-base-200 sm:size-24">
        <%= remote_image_tag article.thumb_url, class: "h-full w-full object-cover", lazy: true %>
      </div>
    <% elsif article.published? %>
      <div class="hidden size-20 flex-shrink-0 overflow-hidden rounded-lg sm:flex sm:size-24" style="background: <%= ColorFromSeed.gradient_css(article.uuid) %>"></div>
    <% else %>
      <div class="hidden size-20 flex-shrink-0 items-center justify-center rounded-lg bg-base-200 text-base-content/20 sm:flex sm:size-24">
        <span class="i-[tabler--photo] size-6"></span>
      </div>
    <% end %>
  <% end %>

  <div class="relative z-10 mt-2.5 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-base-content/60">
    <span class="relative flex items-center gap-1.5">
      <span class="block size-5 flex-shrink-0 overflow-hidden rounded-full">
        <%= render "shared/avatar", user: article.author, thumb: true, class: "block h-full w-full rounded-full" %>
      </span>
      <span class="max-w-[7rem] truncate font-medium text-base-content/70"><%= article.author.name %></span>
      <%= link_to '', user_path(article.author), data: { turbo_frame: '_top' }, class: "absolute inset-0" %>
    </span>

    <span class="truncate">
      <%= render_time_format datetime: article.published_at.rfc3339, format: 'date' do %>
        <%= article.published_at.strftime("%b %d, %Y") %>
      <% end %>
    </span>

    <%# Aggregate, platform-wide early-reader reward figure — not personalized (research.md, FR-004). %>
    <% if article.revenue_usd.to_f.positive? %>
      <span class="tooltip flex items-center gap-1 text-reward [--placement:top]" data-tip="Early Reader Rewards">
        <span class="i-[tabler--coin] size-3.5"></span>
        <span><%= article.revenue_usd.round(2) %></span>
      </span>
    <% end %>

    <span class="ml-auto flex items-center gap-3">
      <span class="flex items-center gap-1">
        <span class="i-[tabler--message-circle] size-3.5"></span>
        <span><%= article.comments_count %></span>
      </span>
      <% if article.upvote_ratio.present? %>
        <span class="flex items-center gap-1">
          <span class="<%= (article.upvote_ratio.to_i / 100.0) > 0.6 ? 'i-[tabler--thumb-up]' : 'i-[tabler--thumb-down]' %> size-3.5"></span>
          <span><%= article.upvote_ratio %></span>
        </span>
      <% end %>
      <%= link_to article_share_path(article_uuid: article.uuid),
        data: { turbo_frame: :modal },
        class: "relative z-10 flex items-center hover:text-base-content" do %>
        <span class="i-[tabler--share] size-3.5"></span>
      <% end %>
    </span>
  </div>
</article>
