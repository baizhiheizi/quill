<%= turbo_stream.replace "#{dom_id @article}_save_status" do %>
  <%= render "articles/save_status", article: @article, status: :saved %>
<% end %>

<%= turbo_stream.replace "#{dom_id @article}_updated_at" do %>
  <%= render "articles/updated_at", article: @article %>
<% end %>

<%= turbo_stream.update "#{dom_id @article}_words_count" do %>
  <%= t("words_count") %>:<%= @article.words_count %>
<% end %>

<%= turbo_stream.update "article-form-meta" do %>
  <span data-article-form-lock-version-param="<%= @article.lock_version %>"></span>
<% end %>
