<div 
  data-controller="article-form" 
  data-article-form-draft-key-value="quill_article_draft" 
  data-article-form-new-record-value="true" 
  data-article-form-dirty-value="false" 
  data-article-form-active-tab-value="edit"
  class="article-form--new">

  <div class="w-full fixed left-0 top-0 z-50 bg-base-100">
    <div class="max-w-xl lg:max-w-2xl 2xl:max-w-3xl mx-auto px-4 py-3 sm:px-0 flex items-center text-sm sm:text-base">

      <%= link_to root_path, class: 'mr-2 smmr-4' do %>
        <%= image_tag "logo.svg", class: 'w-auto h-10 hidden sm:block' %>
        <%= image_tag "logo.png", class: 'w-auto h-6 sm:hidden' %>
      <% end %>

      <div 
        data-action="click->article-form#edit" 
        data-article-form-target="editButton"
        class="cursor-pointer py-1 border-b-2 border-primary mx-2 hidden">
        <%= t('edit') %>
      </div>

      <div class="ml-auto btn btn-primary btn-sm sm:btn-md rounded-full mr-2" 
        data-action="click->article-form#submit">
        <%= t('save_draft') %>
      </div>
      
      <%= link_to dashboard_authorings_path, 
        data: {
          controller: 'prefetch'
        },
        class: "mx-2", 
        role: "menuitem", 
        tabindex: "-1" do %>
        <div class="avatar mx-2 <%= from_mixin_messenger? ? 'mr-20' : '' %>">
          <div class="size-8 rounded-full">
            <%= image_tag current_user.avatar_thumb, class: "rounded-full" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="w-full mx-auto relative py-12 sm:py-24 px-4 sm:px-0">
    <%= render "articles/form", article: @article %>
  </div>
</div>
