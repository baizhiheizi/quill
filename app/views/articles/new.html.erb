<div 
  data-controller="article-form" 
  data-article-form-draft-key-value="quill_article_draft" 
  data-article-form-new-record-value="true" 
  data-article-form-dirty-value="false" 
  data-article-form-active-tab-value="edit"
  class="article-form--new">

  <div class="fixed left-0 top-0 z-50 w-full border-b border-base-300 bg-base-100/95 backdrop-blur-sm">
    <div class="mx-auto flex max-w-xl items-center justify-between px-4 py-3 text-sm sm:max-w-2xl sm:px-6 sm:text-base 2xl:max-w-3xl">

      <%= link_to root_path, class: 'mr-2 sm:mr-4' do %>
        <%= image_tag "logo.svg", class: 'w-auto h-8 hidden sm:block' %>
        <%= image_tag "logo.png", class: 'w-auto h-6 sm:hidden' %>
      <% end %>

      <div class="flex items-center space-x-3 sm:space-x-4">
        <div class="btn btn-soft btn-sm rounded-full font-medium" 
          data-action="click->article-form#submit">
          <%= t('save_draft') %>
        </div>
        
        <%= link_to dashboard_authorings_path, 
          data: { controller: 'prefetch' },
          role: "menuitem", 
          tabindex: "-1" do %>
          <div class="avatar <%= from_mixin_messenger? ? 'mr-16' : '' %>">
            <div class="size-8 rounded-full">
              <%= render "shared/avatar", user: current_user, thumb: true, class: "rounded-full" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="w-full mx-auto relative py-12 sm:py-24 px-4 sm:px-0">
    <%= render "articles/form", article: @article %>
  </div>
</div>
