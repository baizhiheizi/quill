<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('share') do %>
    <%= render "shared/share_options",
      share_url: article_url(@article),
      share_title: @article.title,
      mixin_href: (from_mixin_messenger? ? share_to_mixin(article_url(@article), title: @article.title, description: @article.intro, icon_url: @article.author.avatar_url) : nil) %>
  <% end %>
<% end %>
