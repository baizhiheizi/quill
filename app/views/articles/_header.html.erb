<% if article.collection.present? %>
  <%= link_to collection_path(article.collection_id), class: "mb-6 flex items-center gap-3 truncate rounded-lg bg-base-200 px-4 py-2 text-sm transition-colors hover:bg-base-300/60" do %>
    <%= remote_image_tag article.collection.cover_url, class: "size-8 flex-shrink-0 rounded-full" %>
    <span class="text-base-content/60"><%= t('published_in') %></span>
    <span class="truncate font-medium text-base-content"><%= article.collection.name %></span>
  <% end %>
<% end %>

<div class="mb-5 flex items-center justify-between">
  <div class="relative flex items-center gap-3 truncate">
    <span class="block size-10 flex-shrink-0 overflow-hidden rounded-full">
      <%= render "shared/avatar", user: article.author, thumb: true, class: "block h-full w-full rounded-full" %>
    </span>
    <div class="truncate leading-tight">
      <div class="truncate text-base font-semibold text-base-content"><%= article.author.name %></div>
      <%= render "users/user_uid", user: article.author %>
    </div>
    <%= link_to '', user_path(article.author), data: { controller: 'prefetch' }, class: "absolute inset-0" %>
  </div>

  <%= link_to article_share_path(article_uuid: @article.uuid),
    data: {
      turbo_frame: :modal
    },
    class: "relative z-10 hidden items-center text-base-content/60 transition-colors hover:text-base-content sm:flex" do %>
    <span class="i-[tabler--share] size-5"></span>
  <% end %>
</div>

<h1 class="font-display mb-4 text-2xl leading-tight font-medium text-ellipsis text-base-content lg:text-4xl">
  <%= article.title %>
</h1>

<% if article.tags.present? %>
  <div class="mb-4 flex max-w-full items-center gap-2 overflow-x-auto scrollbar-hide">
    <% article.tags.each do |tag| %>
      <%= link_to tag.name,
        articles_path(tag: tag.name),
        data: {
          controller: 'prefetch'
        },
        class: "tag-chip min-w-max px-2.5 py-1 text-sm" %>
    <% end %>
  </div>
<% end %>

<div class="mb-5 flex items-center justify-between text-sm text-base-content/60">
  <span>
    <% if article.published_at.present? %>
      <%= render_time_format datetime: article.published_at.utc.rfc3339 do %>
        <%= article.published_at.strftime("%Y-%m-%d %H:%M") %>
      <% end %>
    <% else %>
      <%= render_time_format datetime: article.updated_at.utc.rfc3339 do %>
        <%= article.updated_at.strftime("%Y-%m-%d %H:%M") %>
      <% end %>
    <% end %>
  </span>

  <span><%= t("words_count") %>: <%= article.words_count %></span>
</div>

<div class="mb-6 rounded-lg bg-base-200 px-4 py-3 break-words text-base-content/70">
  <%= article.intro %>
</div>

<% if article.cover.attached? %>
  <%= link_to article.cover_url, 
    class: "photoswipe block rounded-lg overflow-hidden", 
    target: "_blank",
    width: article.cover.metadata&.[]('width'),
    height: article.cover.metadata&.[]('height'),
    data: {
      pswp_src: article.cover_url,
      pswp_width: article.cover.metadata&.[]('width'),
      pswp_height: article.cover.metadata&.[]('height'),
    } do %>
    <%= remote_image_tag article.cover_url, class: "w-full" %>
  <% end %>
<% end %>
