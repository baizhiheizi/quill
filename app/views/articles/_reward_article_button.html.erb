<% size ||= 'lg' %>

<% if current_user.present? %>
  <%= link_to new_pre_order_path(order_type: :reward_article, article_uuid: article.uuid), 
    data: {
      turbo_frame: :modal
    },
    class: "btn btn-error rounded-full #{size == 'lg' ? 'btn-lg' : 'btn-sm'} no-underline flex items-center space-x-2" do %>
    <span><%= t('reward') %></span>
  <% end %>
<% elsif from_mixin_messenger? %>
  <%= link_to t('reward'), 
    login_path(return_to: user_article_url(article.author, article.uuid)), 
    class: "btn btn-error rounded-full #{size == 'lg' ? 'btn-lg' : 'btn-sm'} no-underline flex items-center space-x-2" %>
<% else %>
  <%= link_to t('reward'), 
    login_path(return_to: user_article_url(article.author, article.uuid)), 
    data: { turbo_frame: :modal }, 
    class: "btn btn-error rounded-full #{size == 'lg' ? 'btn-lg' : 'btn-sm'} no-underline flex items-center space-x-2" %>
<% end %>
