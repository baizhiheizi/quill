<%# `inset-x-0` (not a negative margin) spans the fixed bar full-width
    regardless of the surrounding column's own padding, avoiding horizontal
    overflow on mobile (SC-008). %>
<div data-controller="floating" id="<%= dom_id(article) %>_floating_bar" class="fixed inset-x-0 bottom-0 z-30 translate-y-24 border-t border-base-300 bg-base-100 px-4 py-3 transition ease-in-out sm:hidden">
  <div class="flex w-full items-center justify-between">
    <%# Consult the controller's primed `upvote_article_actions` /
        `downvote_article_actions` Sets instead of calling
        `user.upvote_article?(article)` / `downvote_article?(article)` —
        each of those action_store helpers does 1 SELECT per call, and this
        partial consults each twice (icon state + button target), so without
        the prime the mobile show view fires 4 extra SELECTs. Fall back to
        the live helper when the partial is rendered from another site
        (e.g. a feed card, or the turbo_stream response from
        `UpvotedArticlesController#update`). %>
    <% upvoted = defined?(@preloaded_upvoted_article_ids) ? @preloaded_upvoted_article_ids.include?(article.id) : user&.upvote_article?(article) %>
    <% downvoted = defined?(@preloaded_downvoted_article_ids) ? @preloaded_downvoted_article_ids.include?(article.id) : user&.downvote_article?(article) %>
    <div class="grid grid-cols-3">
      <div class="relative flex items-center space-x-1 border-inherit px-2">
        <span class="i-[tabler--thumb-up] size-5 <%= upvoted ? 'text-primary' : 'text-base-content/50' %>"></span>
        <span class="text-sm text-base-content/70">
          <%= article.upvotes_count %>
        </span>
        <% if user.blank? %>
          <% if from_mixin_messenger? %>
            <%= link_to '', login_path(return_to: user_article_url(article.author, article.uuid)), class: 'absolute inset-0' %>
          <% else %>
            <%= link_to '', login_path(return_to: user_article_url(article.author, article.uuid)), data: { turbo_frame: :modal }, class: 'absolute inset-0' %>
          <% end %>
        <% elsif upvoted %>
          <%= link_to '', upvoted_article_path(article), data: { turbo_method: :delete }, class: 'absolute inset-0' %>
        <% else %>
          <%= link_to '', upvoted_article_path(article), data: { turbo_method: :put }, class: 'absolute inset-0' %>
        <% end %>
      </div>
      <div class="relative flex items-center space-x-1 border-inherit px-2">
        <span class="i-[tabler--thumb-down] size-5 <%= downvoted ? 'text-error' : 'text-base-content/50' %>"></span>
        <span class="text-sm text-base-content/70">
          <%= article.downvotes_count %>
        </span>
        <% if user.blank? %>
          <% if from_mixin_messenger? %>
            <%= link_to '', login_path(return_to: user_article_url(article.author, article.uuid)), class: 'absolute inset-0' %>
          <% else %>
            <%= link_to '', login_path(return_to: user_article_url(article.author, article.uuid)), data: { turbo_frame: :modal }, class: 'absolute inset-0' %>
          <% end %>
        <% elsif downvoted %>
          <%= link_to '', downvoted_article_path(article), data: { turbo_method: :delete }, class: 'absolute inset-0' %>
        <% else %>
          <%= link_to '', downvoted_article_path(article), data: { turbo_method: :put }, class: 'absolute inset-0' %>
        <% end %>
      </div>
      <%= link_to article_comments_path(article.uuid),
        data: {
          turbo_frame: :modal,
        },
        class: "px-2 flex items-center space-x-1" do %>
        <span class="i-[tabler--message-circle] size-5 text-base-content/50"></span>
        <span class="text-sm text-base-content/70">
          <%= article.comments.count %>
        </span>
      <% end %>
    </div>
    <% if article.author == user %>
      <span class="block size-8 flex-shrink-0 overflow-hidden rounded-full">
        <%= render "shared/avatar", user:, thumb: true, class: "block h-full w-full rounded-full" %>
      </span>
    <% elsif article.authorized? user %> 
      <%= render "articles/reward_article_button", article: article, size: 'sm' %>
    <% else %>
      <%= render "articles/buy_article_button", article: article, size: 'sm' %>
    <% end %>
  </div>
  <div style="height:env(safe-area-inset-bottom)"></div>
</div>
