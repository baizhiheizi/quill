<%# Reading Library — status-grouped sections replacing the old flat 5-tab
    strip (specs/005-dashboard-ux-redesign, US4). Orders/Payments/Transfers
    move to the unified Finances section (research.md, data-model.md); this
    page keeps only reading-native sub-areas plus a reader-earnings shortcut
    (FR-016–FR-018). Every section reuses its existing controller/turbo-frame
    endpoint unchanged. %>
<div class="space-y-10">
  <h1 class="font-display text-2xl font-medium text-base-content"><%= t('read') %></h1>

  <section id="read-bought">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('bought') %></h2>
    <%= turbo_frame_tag "my_bought_articles", src: dashboard_articles_path(tab: :bought), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="read-comments">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('my_comments') %></h2>
    <%= turbo_frame_tag "my_comments", src: dashboard_comments_path, loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="read-subscriptions">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('my_subscriptions') %></h2>
    <%= turbo_frame_tag "my_subscriptions", src: dashboard_subscriptions_path, loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="read-earnings">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('readers_revenue') %></h2>
    <%= turbo_frame_tag "my_transfers_stats", src: dashboard_transfers_stats_path(role: :reader) %>
    <%= turbo_frame_tag "my_transfers", src: dashboard_transfers_path(tab: :reader), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>
</div>
