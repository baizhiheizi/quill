<%# Author Workspace — status-grouped sections replacing the old flat 5-tab
    strip (specs/005-dashboard-ux-redesign, US3). Every section reuses its
    existing controller/turbo-frame endpoint unchanged (FR-012–FR-015); only
    the presentation groups them together instead of hiding all but one
    behind a tab switch. %>
<div class="space-y-10">
  <div class="flex items-center justify-between">
    <h1 class="font-display text-2xl font-medium text-base-content"><%= t('write') %></h1>
    <%= link_to new_article_path, class: "btn btn-primary btn-sm rounded-full" do %>
      <span class="i-[tabler--edit] size-4"></span>
      <%= t('write') %>
    <% end %>
  </div>

  <section id="write-drafted">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('drafted') %></h2>
    <%= turbo_frame_tag "my_drafted_articles", src: dashboard_articles_path(tab: :drafted), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="write-published">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('published') %></h2>
    <%= turbo_frame_tag "my_published_articles", src: dashboard_articles_path(tab: :published), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="write-hidden">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('hidden') %></h2>
    <%= turbo_frame_tag "my_hidden_articles", src: dashboard_articles_path(tab: :hidden), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="write-collections">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('collections') %></h2>
    <%= turbo_frame_tag "my_collections", src: dashboard_collections_path, loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>

  <section id="write-earnings">
    <h2 class="mb-3 text-sm font-semibold text-base-content"><%= t('author_revenue') %></h2>
    <%= turbo_frame_tag "my_transfers_stats", src: dashboard_transfers_stats_path %>
    <%= turbo_frame_tag "my_transfers", src: dashboard_transfers_path(tab: :author), loading: :lazy do %>
      <%= render "shared/loading" %>
    <% end %>
  </section>
</div>
