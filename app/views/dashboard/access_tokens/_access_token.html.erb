<div id="<%= dom_id access_token %>" class="py-2 px-4">
  <div class="flex items-center space-x-4">
    <div class=""><%= access_token.memo %></div>
    <div class="flex-1 flex justify-center">
      <code class="badge badge-ghost badge-sm font-mono"><%= access_token.desensitized_value %></code>
    </div>
    <div class="">
      <%= button_to t('delete'), 
        dashboard_access_token_path(access_token), 
        method: :delete,
        class: "btn btn-ghost btn-error btn-sm" %>
    </div>
  </div>
</div>
