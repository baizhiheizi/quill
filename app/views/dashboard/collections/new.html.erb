<div class="hidden sm:block text-xl font-bold mb-8">
  <%= t('new_collection') %>
</div>

<% content_for :topbar do %>
  <div class="flex items-center px-4 h-12">
    <%= link_to :back, class: "pr-2" do %>
      <span class="i-[tabler--chevron-left] size-5 font-bold"></span>
    <% end %>
    <span class="font-bold text-lg">
      <%= t('new_collection') %>
    </span>
  </div>
<% end %>

<%= render "collections/form", collection: @collection %>

<% if current_user.collections.listed.blank? %>
  <%= turbo_frame_tag 'modal' do %>
    <%= render_modal title: t('new_collection') do %>
      <div class="mb-12">
        <div class="prose text-base-content">
          <%= MarkdownRenderService.call(t('collection_rule'), type: :full).html_safe %>
        </div>
      </div>
      <div class="flex items-center justify-center">
        <button data-action="modal-component#cancel" class="btn btn-primary rounded-full">
          <%= t('confirm') %>
        </button>
      </div>
    <% end %>
  <% end %>
<% end %>
