<div class="py-4 border-b border-base-300">
  <div class="flex items-center justify-between space-x-4">
    <div class="flex items-center space-x-2">
      <%= render "shared/avatar", user: comment.author, thumb: true, class: "w-8 h-8 rounded-full" %>
      <div class="truncate max-w-24">
        <%= comment.author.name %>
      </div>
    </div>
    <%= render_time_format datetime: comment.created_at.rfc3339 do %>
      <span class="opacity-80 min-w-fit">
        <%= comment.created_at.strftime("%Y-%m-%d %H:%M") %>
      </span>
    <% end %>
  </div>
  <div class="prose-comment">
    <%= comment.content_as_html.html_safe %>
  </div>
</div>
