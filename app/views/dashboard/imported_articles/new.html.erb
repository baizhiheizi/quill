<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('import_from_mirror') do %>
    <div class="max-w-full mx-auto">
      <div class="mb-6">
        <%= t('confirm_to_import_from_mirror') %>
      </div>
      <%= button_to t('import'), 
        dashboard_imported_articles_path(@article), 
        class: "btn btn-primary btn-block text-lg"
      %>
    </div>
  <% end %>
<% end %>
