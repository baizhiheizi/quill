<div id="<%= dom_id article %>_draft" class="border-b border-base-300 py-4 flex items-center justify-between space-x-4">
  <%= link_to article.title.presence || t('articles.title_placeholder'), 
    edit_article_path(article.uuid), 
    data: { 
      turbo_frame: '_top'
    }, 
    class: "relative text-lg font-bold truncate" %>
  <div class="flex items-center space-x-2">
    <%= render_time_format datetime: article.updated_at.rfc3339, class: "opacity-80" do %>
      <%= article.updated_at.strftime("%Y-%m-%d %H:%M") %>
    <% end %>
    <% dropdown_button = capture do %>
      <span class="i-[tabler--chevron-down] size-4 opacity-60"></span>
    <% end %>
    <%= render_dropdown button: dropdown_button do %>
      <%= link_to t('delete'), 
        new_dashboard_deleted_article_path(uuid: article), 
        data: {
          turbo_frame: :modal
        },
        class: "btn btn-soft btn-error btn-sm" %>
    <% end %>
  </div>
</div>
