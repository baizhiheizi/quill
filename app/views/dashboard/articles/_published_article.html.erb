<div id="<%= dom_id article %>_published" class="border-b border-base-300 py-4">
  <div class="flex items-start gap-4">
    <% if article.cover_url.present? %>
      <%= link_to user_article_path(article.author, article), data: { controller: "prefetch", turbo_frame: "_top" }, class: "flex-shrink-0" do %>
        <%= remote_image_tag article.cover_url, class: "size-16 rounded-lg object-cover", lazy: true %>
      <% end %>
    <% end %>

    <div class="min-w-0 flex-1">
      <%= link_to article.title, user_article_path(article.author, article),
        data: { controller: "prefetch", turbo_frame: "_top" },
        class: "block truncate text-base font-semibold text-base-content" %>

      <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-base-content/60">
        <span>
          <%= render_time_format datetime: article.published_at.rfc3339 do %>
            <%= article.published_at.strftime("%Y-%m-%d %H:%M") %>
          <% end %>
        </span>
        <% if article.free? %>
          <span class="badge badge-success badge-xs">FREE</span>
        <% else %>
          <span class="inline-flex items-center gap-1">
            <%= remote_image_tag article.currency.icon_url, class: "size-3.5 rounded-full", lazy: true %>
            <%= article.price_tag %> (≈$<%= article.price_usd %>)
          </span>
        <% end %>
        <span class="inline-flex items-center gap-1"><span class="i-[tabler--coin] size-3.5"></span><%= article.revenue_usd.round(2) %></span>
        <span class="inline-flex items-center gap-1"><span class="i-[tabler--message] size-3.5"></span><%= article.comments_count %></span>
        <span class="inline-flex items-center gap-1"><span class="i-[tabler--thumb-up] size-3.5"></span><%= article.upvotes_count %></span>
        <span class="inline-flex items-center gap-1"><span class="i-[tabler--thumb-down] size-3.5"></span><%= article.downvotes_count %></span>
      </div>

      <div class="mt-2 flex items-center gap-4 text-sm text-primary">
        <%= link_to t('stats'), dashboard_article_path(article.uuid), data: { controller: 'prefetch', turbo_frame: '_top' } %>
        <%= link_to t('edit'), edit_article_path(article.uuid), data: { controller: 'prefetch', turbo_frame: '_top' } %>
        <%= button_to t('hide'), dashboard_published_article_path(article.uuid), method: :delete, class: "bg-transparent cursor-pointer p-0 font-normal text-primary" %>
      </div>
    </div>
  </div>
</div>
