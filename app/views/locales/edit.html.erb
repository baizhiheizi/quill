<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('language') do %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <% { 'en' => 'English', 'zh-CN' => '中文', 'ja' => '日本語' }.each do |locale, label| %>
        <%= link_to label,
          "/#{locale}",
          data: { turbo_frame: '_top' },
          class: "btn rounded-full #{current_locale == locale ? 'btn-primary' : 'btn-outline btn-primary'}" %>
      <% end %>
    </div>
  <% end %>
<% end %>
