<div class="mb-5 flex items-start justify-between gap-4">
  <h1 class="font-display flex-1 text-2xl leading-tight font-medium text-ellipsis text-base-content lg:text-3xl">
    <%= collection.name %>
  </h1>
  <%= link_to collection_share_path(collection.uuid), 
    data: {
      turbo_frame: :modal
    },
    class: "relative z-10 hidden items-center text-base-content/60 transition-colors hover:text-base-content sm:flex" do %>
    <span class="i-[tabler--share] size-5"></span>
  <% end %>
</div>

<div class="relative mb-6 flex items-center gap-3 truncate">
  <span class="block size-10 flex-shrink-0 overflow-hidden rounded-full">
    <%= render "shared/avatar", user: collection.author, thumb: true, class: "block h-full w-full rounded-full" %>
  </span>
  <div class="truncate leading-tight">
    <div class="truncate text-base font-semibold text-base-content"><%= collection.author.name %></div>
    <%= render "users/user_uid", user: collection.author %>
  </div>
  <%= link_to '', user_path(collection.author), data: { controller: 'prefetch' }, class: "absolute inset-0" %>
</div>

<div class="mb-6">
  <div class="mb-4 flex items-center gap-2">
    <%= remote_image_tag collection.currency.icon_url, class: "size-6 rounded-full" %>
    <span class="font-display text-xl font-medium text-base-content"><%= collection.price_tag %></span>
    <span class="text-sm text-base-content/50">
      ≈$<%= collection.price_usd %>
    </span>
  </div>

  <% if !collection.authorized?(current_user) %>
    <div class="btn btn-primary relative w-full rounded-full font-medium lg:w-48">
      <span><%= t('buy_collection') %></span>
      <% if current_user.present? && current_user.default_payment.present? %>
        <%= form_for PreOrder.new(
          order_type: :buy_collection,
          item: collection,
          asset_id: collection.asset_id,
          amount: collection.price
        ) do |form| %>
          <%= form.hidden_field :order_type %>
          <%= form.hidden_field :item_id %>
          <%= form.hidden_field :item_type %>
          <%= form.hidden_field :asset_id %>
          <%= form.hidden_field :amount %>
          <%= form.hidden_field :type, value: current_user.default_payment %>
          <%= form.submit '', class: "absolute inset-0 cursor-pointer w-full" %>
        <% end %>
      <% elsif from_mixin_messenger? %>
        <%= link_to '', login_path(return_to: collection_url(collection.uuid)), class: "block absolute inset-0" %>
      <% else %>
        <%= link_to '', login_path(return_to: collection_url(collection.uuid)),
          data: { 
            turbo_frame: :modal
          },
        class: "block absolute inset-0" %>
      <% end %>
    </div>
  <% elsif collection.author != current_user %>
    <div class="relative flex items-center gap-1.5 justify-end text-success">
      <span class="i-[tabler--circle-check] size-5"></span>
      <span class="text-base-content/70"><%= t('subscribed') %></span>
    </div>
  <% end %>
</div>

<%= render "collections/stats", collection: collection %>
