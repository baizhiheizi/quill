<div class="grid grid-cols-2 gap-3">
  <div class="rounded-lg bg-base-200 p-3 text-center">
    <div class="font-display mb-1 text-2xl font-medium text-base-content">
      <%= (collection.revenue_ratio * 100).floor(2) %>%
    </div>
    <div class="text-sm text-base-content/60">
      <%= t('collection_revenue') %>
    </div>
  </div>
  <div class="relative rounded-lg bg-base-200 p-3 text-center">
    <div class="font-display mb-1 text-2xl font-medium text-base-content">
      <%= collection.orders_count %>
    </div>
    <div class="relative text-sm text-base-content/60">
      <%= t('subscribers') %>
    </div>
    <%= link_to '', 
      collection_subscribers_path(collection.uuid),
      data: {
        turbo_frame: :modal
      },
      class: "absolute inset-0"
    %>
  </div>
</div>
