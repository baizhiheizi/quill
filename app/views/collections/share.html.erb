<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('share') do %>
    <%= render "shared/share_options",
      share_url: collection_url(@collection.uuid),
      share_title: @collection.name,
      mixin_href: (from_mixin_messenger? ? share_to_mixin(collection_url(@collection.uuid), title: @collection.name, description: @collection.description, icon_url: @collection.cover_url) : nil) %>
  <% end %>
<% end %>
