<%= turbo_frame_tag 'modal' do %>
  <%= render_modal title: t('connect_wallet') do %>
    <div class="space-y-6">
      <p class="text-center text-sm text-base-content/60">
        <%= t('connect_wallet_modal_intro', default: 'Sign in with Mixin to read, write, and receive crypto rewards on Quill.') %>
      </p>

      <%= button_to auth_mixin_path(return_to: params[:return_to] || request.referer),
        method: :post,
        data: { turbo: false },
        class: "btn btn-primary relative w-full justify-center rounded-full py-3 text-base font-medium" do %>
        <span class="absolute left-4 flex size-8 items-center justify-center">
          <%= image_tag 'mixin-logo.png', class: 'size-7' %>
        </span>
        <span>Mixin Messenger</span>
      <% end %>

      <p class="text-center text-xs leading-relaxed text-base-content/50">
        <%= t('by_connecting_your_wallet_you_agree_to') %>
        <%= link_to t('terms_of_service'), 'https://docs.quill.im/terms-of-service', target: "_blank", class: "font-medium text-base-content/70 underline-offset-2 hover:underline" %>
        <%= t('and') %>
        <%= link_to t('privacy_policy'), 'https://docs.quill.im/privacy-policy', target: "_blank", class: "font-medium text-base-content/70 underline-offset-2 hover:underline" %>
      </p>
    </div>
  <% end %>
<% end %>

<div class="my-16 flex items-center justify-center">
  <% if from_mixin_messenger? %>
    <%= button_to t('connect_wallet'), auth_mixin_path, method: :post, data: { turbo: false }, class: "btn btn-primary rounded-full px-6" %>
  <% else %>
    <%= link_to t('connect_wallet'), login_path, data: { turbo_frame: :modal }, class: "btn btn-primary rounded-full px-6" %>
  <% end %>
</div>
