<%= form_with url: admin_sessions_path, method: :get, class: "flex items-center flex-wrap" do |form| %>
  <%= form.select :order_by, 
    [
      ['Created DESC', 'created_at_desc'], 
      ['Created ASC', 'created_at_asc'], 
    ], 
    { selected: @order_by }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.hidden_field :user_id, value: params[:user_id] %>
  <%= form.submit :Query, class: "btn btn-primary btn-sm m-1" %>
<% end %>
