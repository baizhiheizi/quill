<div class="flex items-center space-x-4 mb-4">
  <%= link_to 'Home', admin_root_path %>
  <span>/</span>
  <%= link_to 'Users', admin_users_path %>
  <span>/</span>
  <span><%= @user.name %></span>
</div>

<div class="bg-base-100 rounded-lg p-4 shadow">
  <div class="flex items-center space-x-2 mb-4">
    <%= render "shared/avatar", user: @user, thumb: true, class: "w-12 h-12 rounded-full" %>
    <div>
      <div><%= @user.name %></div>
      <div class="text-sm opacity-70"><%= @user.uid %></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-8">
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">ID:</span> 
      <span><%= @user.id %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">UID:</span> 
      <span><%= @user.uid %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Mixin ID:</span> 
      <span><%= @user.mixin_id %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Mixin UUID:</span> 
      <span><%= @user.mixin_uuid %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Wallet:</span> 
      <span>
        <% if @user.wallet.present? %>
          <%= render 'admin/mixin_network_users/field', mixin_network_user: @user.wallet %>
        <% else %>
          -
        <% end %>
      </span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Phone:</span> 
      <span><%= @user.phone.presence || '-' %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Articles:</span> 
      <span><%= @user.articles_count %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Bought Articles:</span> 
      <span><%= @user.bought_articles_count %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Comments:</span> 
      <span><%= @user.comments_count %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Paid:</span> 
      <span>$<%= @user.payment_total_usd.round(4) %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Earn:</span> 
      <span>$<%= @user.revenue_total_usd.round(4) %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Created:</span> 
      <span><%= @user.created_at %></span>
    </div>
    <div class="col-span-1 flex space-x-2">
      <span class="font-bold">Validated:</span> 
      <span><%= @user.validated_at.presence || '-' %></span>
    </div>
  </div>

  <div class=""
    data-controller="tabs"
    data-tabs-active-tab-value="<%= @tab %>"
    data-tabs-active-class-value="border-b-2">
    <div class="flex overflow-auto flex-nowrap scrollbar-hide items-center mb-4 border-b lg:border-none space-x-2">
      <%= link_to admin_user_path(@user, tab: :articles), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "articles",
        } do %>
        Articles
      <% end %>
      <%= link_to admin_user_path(@user, tab: :collections), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "collections",
        } do %>
        Collections
      <% end %>
      <%= link_to admin_user_path(@user, tab: :comments), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "comments",
        } do %>
        Comments
      <% end %>
      <%= link_to admin_user_path(@user, tab: :payments), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "payments",
        } do %>
        Payments
      <% end %>
      <%= link_to admin_user_path(@user, tab: :orders), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "orders",
        } do %>
        Orders
      <% end %>
      <%= link_to admin_user_path(@user, tab: :pre_orders),
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "pre_orders",
        } do %>
        Pre Orders
      <% end %>
      <%= link_to admin_user_path(@user, tab: :transfers),
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "transfers",
        } do %>
        Transfers
      <% end %>
      <%= link_to admin_user_path(@user, tab: :mixin_network_snapshots), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "mixin_network_snapshots",
        } do %>
        Snapshots
      <% end %>
      <%= link_to admin_user_path(@user, tab: :bonuses), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "bonuses",
        } do %>
        Bonus
      <% end %>
      <%= link_to admin_user_path(@user, tab: :non_fungible_outputs), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "non_fungible_outputs",
        } do %>
        NFOs
      <% end %>
      <%= link_to admin_user_path(@user, tab: :sessions), 
        class: "btn btn-soft btn-sm text-base-content",
        data: {
          tabs_target: "tab",
          tabs_tabname_param: "sessions",
        } do %>
        Sessions
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="articles"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_articles', src: admin_articles_path(author_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="collections"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_collections', src: admin_collections_path(author_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="comments"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_comments', src: admin_comments_path(author_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="payments"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_payments', src: admin_payments_path(payer_id: @user.mixin_uuid) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="orders"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_orders', src: admin_orders_path(buyer_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="pre_orders"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_pre_orders', src: admin_pre_orders_path(payer_id: @user.mixin_uuid) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="transfers"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_transfers', src: admin_transfers_path(opponent_id: @user.mixin_uuid) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="mixin_network_snapshots"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_mixin_network_snapshots', src: admin_mixin_network_snapshots_path(opponent_id: @user.mixin_uuid) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="bonuses"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_bonuses', src: admin_bonuses_path(user_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="non_fungible_outputs"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_non_fungible_outputs', src: admin_non_fungible_outputs_path(user_id: @user.mixin_uuid) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
    <div class="hidden"
        data-tabs-content-param="sessions"
        data-tabs-target="content">
      <%= turbo_frame_tag 'admin_sessions', src: admin_sessions_path(user_id: @user.id) do %>
        <%= render "shared/loading" %>
      <% end %>
    </div>
  </div>
</div>
