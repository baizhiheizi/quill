<%= form_with url: admin_mixin_network_users_path, method: :get, class: "flex items-center flex-wrap" do |form| %>
  <%= form.select :type, 
    [
      ['All Types', 'all'], 
      ['Splitter', 'Splitter']
    ], 
    { selected: @type }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :state, 
    [
      ['All States', 'all'], 
      ['Ready', 'ready'],
      ['Unready', 'unready'],
    ], 
    { selected: @state }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :owner_type, 
    [
      ['All Owners', 'all'], 
      ['Article', 'Article'],
      ['User', 'User'],
    ], 
    { selected: @owner_type }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :order_by, 
    [
      ['Created DESC', 'created_at_desc'], 
      ['Created ASC', 'created_at_asc'], 
    ], 
    { selected: @order_by }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.text_field :query, value: @query, placeholder: "Search", class: "input input-bordered input-sm m-1" %>
  <%= form.submit :Query, class: "btn btn-primary btn-sm m-1" %>
<% end %>
