<tr>
  <td class="p-4">
    <%= mixin_network_user.type || '-' %>
  </td>
  <td class="p-4">
    <%= mixin_network_user.id %>
  </td>
  <td class="p-4">
    <%= render "admin/mixin_network_users/field", mixin_network_user: mixin_network_user %>
  </td>
  <td class="p-4">
    <% if mixin_network_user.owner.is_a? Article %>
      <%= render "admin/articles/field", article: mixin_network_user.owner %>
    <% elsif mixin_network_user.owner.is_a? User %>
      <%= render "admin/users/field", user: mixin_network_user.owner %>
    <% else %>
      -
    <% end %>
  </td>
  <td class="p-4">
    <div class='flex justify-center'>
      <% if mixin_network_user.ready? %>
        <span class="badge badge-success badge-xs">Ready</span>
      <% else %>
        <span class="badge badge-neutral">Unready</span>
      <% end %>
    </div>
  </td>
  <td class="p-4">
    <%= mixin_network_user.created_at %>
  </td>
  <td class="p-4">
    <%= link_to 'Detail', admin_mixin_network_user_path(mixin_network_user), class: "btn btn-primary btn-sm", data: { turbo_frame: "_top" } %>
  </td>
</tr>
