<tr id="<%= dom_id collection %>">
  <td class="p-4">
    <%= collection.id %>
  </td>
  <td class="p-4">
    <%= render "admin/users/field", user: collection.author, tab: 'collections' %>
  </td>
  <td class="p-4">
    <%= render "admin/collections/field", collection: collection %>
  </td>
  <td class="p-4">
    <span class="badge
      <%= case collection.state
        when 'drafted'
          'badge-neutral'
        when 'listed'
          'badge-success'
        when 'hidden'
          'badge-warning'
        end %>">
      <%= collection.state %>
    </span>
  </td>
  <td class="p-4">
    <%= collection.price_tag %>
  </td>
  <td class="p-4">
    <%= collection.revenue_ratio %>
  </td>
  <td class="p-4">
    <%= link_to(@articles_count_by_collection_uuid&.[](collection.uuid) || collection.articles.count, admin_collection_path(collection, tab: 'articles')) %>
  </td>
  <td class="p-4">
    <%= link_to collection.orders_count, admin_collection_path(collection, tab: 'orders') %>
  </td>
  <td class="p-4">
    <%= collection.updated_at %>
  </td>
</tr>
