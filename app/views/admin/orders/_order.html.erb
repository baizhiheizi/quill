<tr>
  <td class="p-4">
    <%= order.id %>
  </td>
  <td class="p-4">
    <%= order.trace_id %>
  </td>
  <td class="p-4">
    <% case order.item %>
    <% when Article %>
      <%= render "admin/articles/field", article: order.item %>
    <% when Collection %>
      <%= render "admin/collections/field", collection: order.item %>
    <% else %>
      -
    <% end %>
  </td>
  <td class="p-4">
    <% if order.buyer.present? %>
      <%= render 'admin/users/field', user: order.buyer, tab: :orders %>
    <% else %>
      <%= order.buyer_id %>
    <% end %>
  </td>
  <td class="p-4">
    <div class="flex items-center space-x-2">
      <%= remote_image_tag order.currency.icon_url, class: "w-10 h-10 rounded" %>
      <span><%= order.price_tag %></span>
    </div>
  </td>
  <td class="p-4">
    <div class="flex justify-center">
      <span class="badge
        <%=
          {
            paid: 'badge-info',
            completed: 'badge-success',
            stale: 'badge-neutral'
          }[order.state.to_sym]
          %>">
        <%= order.state %>
      </span>
    </div>
  </td>
  <td class="p-4">
    <%= order.order_type %>
  </td>
  <td class="p-4">
    <%= order.created_at %>
  </td>
  <td class="p-4">
    <%= link_to 'Detail', admin_order_path(order), class: "btn btn-primary btn-sm", data: { turbo_frame: "_top" } %>
  </td>
</tr>
