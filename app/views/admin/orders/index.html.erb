<div class="flex items-center space-x-4 mb-4">
  <%= link_to 'Home', admin_root_path %>
  <span>/</span>
  <span>Orders</span>
</div>

<div class="p-4 bg-base-100 rounded-lg shadow">
  <%= turbo_frame_tag 'admin_orders' do %>
    <div class="mb-4">
      <%= render 'admin/orders/query' %>
    </div>
    <div data-controller="infinite-scroll" class="w-full overflow-x-scroll scrollbar-hide">
      <table class='table table-zebra w-full min-w-max'>
        <thead>
          <tr class="bg-base-200">
            <th class="p-4">ID</th>
            <th class="p-4">TraceID</th>
            <th class="p-4">Item</th>
            <th class="p-4">Buyer</th>
            <th class="p-4">Total</th>
            <th class="p-4">State</th>
            <th class="p-4">OrderType</th>
            <th class="p-4">Created</th>
            <th class="p-4"></th>
          </tr>
        </thead>
        <tbody id="admin_orders_list">
          <%= render partial: 'admin/orders/order', collection: @orders, as: :order %>
        </tbody>
      </table>
      <div data-infinite-scroll-target='scrollArea'></div>
      <%= render partial: "shared/pagination", locals: { pagy: @pagy } %>
    </div>
  <% end %>
</div>
