<aside
  data-controller="sidebar"
  data-sidebar-open-class-value="<%= %w[w-64].to_json %>"
  data-sidebar-collapse-class-value="<%= %w[w-10 sm:w-16].to_json %>"
  class="sticky top-0 flex items-center overflow-y-scroll scrollbar-hide">
  <div
    data-sidebar-target="sidebar"
    data-action="hover->sidebar#open"
    class="menu flex h-full w-10 flex-col overflow-x-hidden bg-base-100 p-0 transition-transform sm:w-16 sm:p-4">
    <ul class="menu menu-sm w-full gap-1">
      <% [
        ['Dashboard', admin_root_path],
        ['Stats', admin_statistics_path],
        ['Users', admin_users_path],
        ['Articles', admin_articles_path],
        ['Comments', admin_comments_path],
        ['Payments', admin_payments_path],
        ['Orders', admin_orders_path],
        ['PreOrders', admin_pre_orders_path],
        ['Swap Orders', admin_swap_orders_path],
        ['Transfers', admin_transfers_path],
        ['Snapshots', admin_mixin_network_snapshots_path],
        ['Wallets', admin_mixin_network_users_path],
        ['Collections', admin_collections_path],
        ['AR Tx', admin_arweave_transactions_path],
        ['Bonus', admin_bonuses_path],
        ['Sessions', admin_sessions_path],
        ['Logout', admin_logout_path]
      ].each do |label, path| %>
        <li><%= link_to label, path, class: "rounded-lg hover:bg-base-200" %></li>
      <% end %>
    </ul>

    <div class="mt-auto">
      <button data-sidebar-target="openButton" data-action="sidebar#open" class="btn btn-ghost btn-sm w-full justify-start">
        <%= inline_svg_tag "icons/chevron-right.svg", class: "h-4 w-4 opacity-60" %>
      </button>
      <button data-sidebar-target="collapseButton" data-action="sidebar#collapse" class="btn btn-ghost btn-sm hidden w-full justify-start">
        <%= inline_svg_tag "icons/chevron-left.svg", class: "h-4 w-4 opacity-60" %>
        <span>Collapse</span>
      </button>
    </div>
  </div>
</aside>
