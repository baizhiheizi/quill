<%= form_with url: admin_mixin_network_snapshots_path, method: :get, class: "flex items-center flex-wrap" do |form| %>
  <%= form.select :state, 
    [
      ['All States', 'all'], 
      ['Processed', 'processed'],
      ['Unprocessed', 'unprocessed'],
    ], 
    { selected: @state }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :opponent, 
    [
      ['All Opponents', 'all'], 
      ['Quill', 'quill'], 
      ['MTG', 'mtg']
    ], 
    { selected: @opponent }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :direction, 
    [
      ['Both Directions', 'all'], 
      ['Input', 'input'], 
      ['Output', 'output']
    ], 
    { selected: @direction }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :order_by, 
    [
      ['Processed DESC', 'processed_at_desc'], 
      ['Created DESC', 'created_at_desc'], 
      ['Created ASC', 'created_at_asc'], 
    ], 
    { selected: @order_by }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.text_field :query, value: @query, placeholder: "Search", class: "input input-bordered input-sm m-1" %>
  <%= form.hidden_field :user_id, value: params[:user_id] %>
  <%= form.hidden_field :opponent_id, value: params[:opponent_id] %>
  <%= form.submit :Query, class: "btn btn-primary btn-sm m-1" %>
<% end %>
