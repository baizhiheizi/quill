<%= form_with url: admin_statistics_path, method: :get, class: "flex items-center flex-wrap" do |form| %>
  <%= form.select :state, 
    [
      ['All', 'all'], 
      ['Daily', 'DailyStatistic'],
    ], 
    { selected: @state }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :order_by, 
    [
      ['DESC', 'datetime_desc'], 
      ['ASC', 'datetime_asc'], 
    ], 
    { selected: @order_by }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.text_field :query, value: @query, placeholder: "Search", class: "input input-bordered input-sm m-1" %>
  <%= form.submit :Query, class: "btn btn-primary btn-sm m-1" %>
<% end %>
