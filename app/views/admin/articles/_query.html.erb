<%= form_with url: admin_articles_path, method: :get, class: "flex items-center flex-wrap" do |form| %>
  <%= form.select :locale, 
    [
      ['All', 'all'], 
      ['EN', 'en'],
      ['ZH', 'zh'],
      ['JA', 'ja'],
      ['Others', 'others'], 
    ], 
    { selected: @locale }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :state, 
    [
      ['All', 'all'], 
      ['Drafted', 'drafted'],
      ['Published', 'published'],
      ['Hidden', 'hidden'],
      ['Blocked', 'blocked'],
    ], 
    { selected: @state }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.select :order_by, 
    [
      ['Published DESC', 'published_at_desc'], 
      ['Published ASC', 'published_at_asc'], 
      ['Created DESC', 'created_at_desc'], 
      ['Created ASC', 'created_at_asc'], 
      ['Revenue', 'revenue_usd'], 
      ['Orders', 'orders_count'], 
      ['Comments Count', 'comments_count'], 
      ['Upvotes Count', 'upvotes_count'], 
      ['Downvotes Count', 'downvotes_count'], 
    ], 
    { selected: @order_by }, 
    class: "select select-bordered select-sm m-1" %>
  <%= form.text_field :query, value: @query, placeholder: "Search", class: "input input-bordered input-sm m-1" %>
  <%= form.hidden_field :author_id, value: params[:author_id] %>
  <%= form.submit :Query, class: "btn btn-primary btn-sm m-1" %>
<% end %>
