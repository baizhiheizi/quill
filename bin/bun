#!/usr/bin/env ruby
APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT) do
  bun = ENV["PATH"].split(File::PATH_SEPARATOR).
    select { |dir| File.expand_path(dir) != __dir__ }.
    product(["bun", "bun.cmd", "bun.ps1"]).
    map { |dir, file| File.expand_path(file, dir) }.
    find { |file| File.executable?(file) }

  if bun
    exec bun, *ARGV
  else
    $stderr.puts "Bun executable was not detected in the system."
    $stderr.puts "Install Bun at https://bun.sh"
    exit 1
  end
end
