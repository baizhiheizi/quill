#!/usr/bin/env bash

if overmind version &> /dev/null; then
  exec overmind start -f Procfile.dev "$@"
elif foreman version &> /dev/null; then
  exec foreman start -f Procfile.dev -e "" "$@"
else
  echo "Error: neither 'overmind' nor 'foreman' is installed."
  echo "Install one to run the development server:"
  echo "  brew install overmind    # recommended"
  echo "  gem install foreman"
  exit 1
fi
